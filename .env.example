# DorkPlusPremium v2.0.0 Environment Configuration

# Backend Configuration
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0
DEBUG=False
LOG_LEVEL=INFO

# Frontend Configuration
REACT_APP_API_URL=http://localhost:8000/api
REACT_APP_VERSION=2.0.0

# Database Configuration (if using MongoDB)
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=dorkpluspremium

# Security
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
TOKEN_EXPIRY_HOURS=24

# License System
LICENSE_CHECK_ENABLED=True
LICENSE_VALIDATION_URL=https://api.dorkpluspremium.local/validate
HARDWARE_BINDING_ENABLED=True

# Proxy Settings
PROXY_ROTATION_ENABLED=False
DEFAULT_PROXY=None
PROXY_TIMEOUT_SECONDS=10

# Web Scraping
USER_AGENT_ROTATION=True
REQUEST_TIMEOUT=30
MAX_CONCURRENT_REQUESTS=10
RATE_LIMIT_DELAY=1

# Vulnerability Scanning
SQL_PAYLOADS_FILE=payloads/sqli_payloads.txt
XSS_PAYLOADS_FILE=payloads/xss_payloads.txt
LFI_PATTERNS_FILE=payloads/lfi_patterns.txt

# Cloudflare Bypass
CLOUDFLARE_BYPASS_ENABLED=False
CLOUDFLARE_USER_AGENT=Mozilla/5.0

# API Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_ENABLED=True

# CORS Settings
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_CREDENTIALS=True

# Logging
LOG_FILE=logs/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
